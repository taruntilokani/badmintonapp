DirectoryIndex index.php
Options -Indexes

<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
</IfModule>

<FilesMatch "^(db-config|db-config\.example|database)\.php$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Deny from all
  </IfModule>
</FilesMatch>
